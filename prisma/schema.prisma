// Prisma schema — source of truth for the database structure.
// To make a schema change:
//   1. Edit this file
//   2. Run: npx prisma migrate dev --name describe_your_change
//   3. Commit both this file and the generated migration in prisma/migrations/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id             String       @id           // 'burkhardt', 'jose'
  domain         String       @unique       // 'windowsbyburkhardt.com'
  brandName      String
  headline       String
  favicon        String       @default("/favicon.svg")
  fromEmail      String
  recipientEmail String
  ccEmail        String?
  ga4Id          String
  pixelId        String?
  active         Boolean      @default(true)
  submissions    Submission[]
}

model Submission {
  id               Int      @id @default(autoincrement())
  submittedAt      DateTime @default(now())

  // Tenant discriminator
  tenantId         String   @default("burkhardt")
  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  // Required contact info
  name             String
  email            String
  phone            String

  // Optional address
  address          String?
  city             String?
  state            String?
  zip              String?

  // Optional scheduling preferences
  preferredDate    String?
  preferredTime    String?
  preferredContact String?

  // Optional message
  message          String?

  // Optional referral
  referralFirstName String?
  referralLastName  String?
  referralPhone     String?

  // Test lead flag — set via ?isTestLead=true query param so smoke tests
  // can be filtered out of real lead reports.
  isTestLead        Boolean  @default(false)

  // Attribution — populated from URL params on form submit.
  // UTMs are set manually on ad/email destination URLs; click IDs are auto-appended by the platform.
  // Stored on first touch (URL param wins over localStorage) so the source that drove the visit is credited.
  utmSource    String?   // utm_source=facebook | google | email | instagram
  utmMedium    String?   // utm_medium=paid | cpc | email | organic
  utmCampaign  String?   // utm_campaign=spring-windows-2026
  utmContent   String?   // utm_content=carousel-ad-v2  (A/B variant tracking)
  utmTerm      String?   // utm_term=replacement+windows (paid search keyword)
  fbclid       String?   // Facebook click ID — auto-appended by FB Ads; improves CAPI match rate
  gclid        String?   // Google click ID — auto-appended by Google Ads
}
