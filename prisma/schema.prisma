// Prisma schema — source of truth for the database structure.
// To make a schema change:
//   1. Edit this file
//   2. Run: npx prisma migrate dev --name describe_your_change
//   3. Commit both this file and the generated migration in prisma/migrations/

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id             String       @id           // 'burkhardt', 'jose'
  domain         String       @unique       // 'windowsbyburkhardt.com'
  brandName      String
  headline       String
  favicon        String       @default('/favicon.svg')
  fromEmail      String
  recipientEmail String
  ga4Id          String
  active         Boolean      @default(true)
  submissions    Submission[]
}

model Submission {
  id               Int      @id @default(autoincrement())
  submittedAt      DateTime @default(now())

  // Tenant discriminator
  tenantId         String   @default("burkhardt")
  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  // Required contact info
  name             String
  email            String
  phone            String

  // Optional address
  address          String?
  city             String?
  state            String?
  zip              String?

  // Optional scheduling preferences
  preferredDate    String?
  preferredTime    String?
  preferredContact String?

  // Optional message
  message          String?

  // Optional referral
  referralFirstName String?
  referralLastName  String?
  referralPhone     String?
}
