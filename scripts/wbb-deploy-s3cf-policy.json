{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3StaticDeploy",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::wbb-static-prod",
        "arn:aws:s3:::wbb-static-prod/*"
      ]
    },
    {
      "Sid": "CloudFrontInvalidate",
      "Effect": "Allow",
      "Action": [
        "cloudfront:CreateInvalidation"
      ],
      "Resource": "arn:aws:cloudfront::669143131098:distribution/*"
    }
  ]
}
