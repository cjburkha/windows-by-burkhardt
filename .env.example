# Server Configuration
PORT=3000
NODE_ENV=development

# AWS SES Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_SES_FROM_EMAIL=noreply@yourdomain.com

# Email Configuration
RECIPIENT_EMAIL=chris.burkhardt@live.com

# Database (AWS RDS PostgreSQL)
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Dev:  your dev RDS endpoint
# Prod: set as DATABASE_URL secret in GitHub Actions + App Runner env var
DATABASE_URL=postgresql://postgres:password@your-rds-endpoint.rds.amazonaws.com:5432/wbb_dev?sslmode=require

# GA4 Measurement Protocol (email open tracking)
GA4_API_SECRET=

# CloudFront (static asset CDN cache invalidation on deploy)
# Set CLOUDFRONT_DISTRIBUTION_ID as a GitHub Actions secret (e.g. E1ABCDEF12345)
CLOUDFRONT_DISTRIBUTION_ID=
